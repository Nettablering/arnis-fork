---
import Base from "../../layouts/Base.astro";
---

<Base title="Devblog — Worldbuilders">
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold">Devblog</h1>
    <p class="mt-4 text-[var(--color-ink)]/85">
      Build-in-public notes from the team. First post ships once the bake
      pipeline serves a real OSM tile end-to-end.
    </p>
    <ul class="mt-10 space-y-4" aria-label="Posts">
      <li class="text-[var(--color-ink)]/60 italic">No posts yet.</li>
    </ul>
  </section>
</Base>
