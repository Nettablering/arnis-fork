---
import { getCollection } from "astro:content";
import Atlas from "../../layouts/Atlas.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = (d: Date) =>
  d.toISOString().slice(0, 10); // YYYY-MM-DD, stable across locales

// Group posts by year for lat-band rhythm headers.
const byYear = new Map<number, typeof posts>();
for (const p of posts) {
  const y = p.data.date.getUTCFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Atlas
  title="Devblog — Worldbuilders"
  description="Build-in-public field notes from the team turning OpenStreetMap into a Roblox idle empire. Weekly, every Tuesday."
>
  <section class="wrap lat-band" data-lat="LAT BAND 62°N · devblog">
    <p class="eyebrow">Field notes from the bake</p>
    <h1>The <span class="text-aurora">devblog</span>.</h1>
    <p class="lede">
      Slow-burn build-in-public notes — pipeline anatomy, ugly-baby
      screenshots, dead-ends. New post every Tuesday 14:00 UTC. Honest
      about what works, honest about what doesn&rsquo;t.
    </p>
    <ul class="feed-links mono">
      <li><a href="/blog/rss.xml">RSS 2.0</a></li>
      <li><a href="/blog/atom.xml">Atom 1.0</a></li>
      <li><a href="/blog/feed.json">JSON Feed 1.1</a></li>
    </ul>
  </section>

  {posts.length === 0 ? (
    <section class="wrap lat-band" data-lat="LAT BAND 62°N · awaiting first post">
      <div class="empty">
        <p class="empty-line mono">// awaiting tile bake</p>
      </div>
    </section>
  ) : (
    years.map((year) => (
      <section class="wrap lat-band" data-lat={`LAT BAND · ${year}`}>
        <ul class="posts">
          {byYear.get(year)!.map((post) => (
            <li class="post">
              <p class="post-date mono">
                <span class="post-lat">{fmt(post.data.date)}</span>
                <span class="post-sep" aria-hidden="true"></span>
                <span>{post.data.tags.slice(0, 3).join(" · ")}</span>
              </p>
              <h2 class="post-title">
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h2>
              <p class="post-excerpt">{post.data.summary}</p>
              <p class="post-meta mono">
                <a href={`/blog/${post.slug}/`} class="post-readmore">
                  Read post
                  <svg width="12" height="12" viewBox="0 0 14 14" aria-hidden="true">
                    <path d="M2 7 H11 M7 3 L11 7 L7 11" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              </p>
            </li>
          ))}
        </ul>
      </section>
    ))
  )}
</Atlas>

<style>
  .lede { color: var(--fg-soft); font-size: 1.04rem; max-width: 64ch; }
  .text-aurora { color: var(--color-aurora-green); }
  .empty { display: flex; flex-direction: column; align-items: center; padding: 2rem 0; }
  .empty-line {
    color: var(--color-aurora-green);
    letter-spacing: 0.2em;
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .feed-links {
    list-style: none;
    padding: 0;
    margin: 1.4rem 0 0;
    display: flex;
    gap: 1.2rem;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-faint);
  }
  .feed-links a { color: var(--fg-faint); text-decoration: none; border-bottom: 1px solid var(--rule); padding-bottom: 2px; }
  .feed-links a:hover { color: var(--color-aurora-green); border-bottom-color: var(--color-aurora-green); }

  .posts { list-style: none; padding: 0; margin: 0; }
  .post {
    padding: 2.4rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .post:last-child { border-bottom: none; }
  .post-date {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--fg-faint);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .post-sep {
    display: inline-block;
    width: 1.4rem;
    border-top: 1px solid var(--rule);
  }
  .post-title {
    margin: 0.6rem 0 0.7rem;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 420;
    letter-spacing: -0.015em;
    line-height: 1.15;
  }
  .post-title a { color: var(--fg); text-decoration: none; }
  .post-title a:hover { color: var(--color-aurora-green); }
  .post-excerpt { color: var(--fg-soft); max-width: 64ch; font-size: 1rem; }
  .post-meta { margin-top: 1rem; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; }
  .post-readmore {
    color: var(--color-aurora-green);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .post-readmore:hover { text-decoration: underline; text-underline-offset: 4px; }
</style>
