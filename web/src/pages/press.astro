---
import Base from "../layouts/Base.astro";
---

<Base title="Press kit — Worldbuilders">
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold">Press kit</h1>
    <p class="mt-4 text-[var(--color-ink)]/85">
      Logos, screenshots, factsheet, founder bios and review keys land here
      ahead of launch. For pre-launch press enquiries, email
      <a href="mailto:press@worldbuilders.app">press@worldbuilders.app</a>.
    </p>
    <p class="mt-8 text-sm text-[var(--color-ink)]/60">
      Full kit ships per Q341 / Q512.
    </p>
  </section>
</Base>
