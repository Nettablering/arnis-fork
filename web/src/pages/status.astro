---
import Base from "../layouts/Base.astro";
---

<Base title="Status — Worldbuilders">
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold">System status</h1>
    <p class="mt-4 text-[var(--color-ink)]/85">
      Live availability dashboard for the public API, web companion, and the
      Roblox bake pipeline.
    </p>
    <p class="mt-8">
      <a
        href="https://status.worldbuilders.quicktoolry.com"
        class="inline-block px-5 py-3 rounded-lg bg-[var(--color-neon-green)] text-[var(--color-deep-blue)] font-semibold no-underline"
        >Open status dashboard &rarr;</a
      >
    </p>
    <p class="mt-8 text-sm text-[var(--color-ink)]/60">
      Hosted status page (Uptime Kuma) ships per Q522.
    </p>
  </section>
</Base>
