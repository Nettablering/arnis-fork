---
// Top navigation — cartographic; small wordmark + compass dot.
const links = [
  { href: "/developers", label: "Developers" },
  { href: "/blog", label: "Devblog" },
  { href: "/press", label: "Press" },
  { href: "/status", label: "Status" },
];
const path = Astro.url.pathname;
---

<header class="nav-atlas">
  <nav aria-label="Primary" class="wrap nav-inner">
    <a href="/" class="brand" aria-label="Worldbuilders — home">
      <svg width="22" height="22" viewBox="0 0 22 22" aria-hidden="true" class="brand-mark">
        <circle cx="11" cy="11" r="9.5" fill="none" stroke="currentColor" stroke-width="1" opacity="0.7" />
        <line x1="11" y1="1" x2="11" y2="21" stroke="currentColor" stroke-width="0.8" opacity="0.5" />
        <line x1="1" y1="11" x2="21" y2="11" stroke="currentColor" stroke-width="0.8" opacity="0.5" />
        <polygon points="11,3 9,11 11,19 13,11" fill="var(--color-aurora-green)" />
        <circle cx="11" cy="11" r="1.8" fill="var(--color-ink)" />
      </svg>
      <span class="brand-word">Worldbuilders</span>
      <span class="brand-sub mono">N 62°28′ · E 6°09′</span>
    </a>
    <ul class="nav-links">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            aria-current={path.startsWith(l.href) ? "page" : undefined}
          >{l.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .nav-atlas {
    border-bottom: 1px solid var(--rule);
    position: relative;
    z-index: 5;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.4rem;
    padding-bottom: 1.4rem;
    gap: 1rem;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--fg);
  }
  .brand-mark {
    color: var(--fg-soft);
    align-self: center;
  }
  .brand-word {
    font-family: var(--font-display);
    font-size: 1.18rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .brand-sub {
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    color: var(--fg-faint);
    text-transform: uppercase;
  }
  .nav-links {
    display: flex;
    list-style: none;
    gap: clamp(0.8rem, 2.4vw, 1.8rem);
    margin: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .nav-links a {
    color: var(--fg-soft);
    text-decoration: none;
    padding: 0.3rem 0;
    border-bottom: 1px solid transparent;
    transition: color 200ms ease, border-color 200ms ease;
  }
  .nav-links a:hover,
  .nav-links a[aria-current="page"] {
    color: var(--color-aurora-green);
    border-bottom-color: var(--color-aurora-green);
  }
  @media (max-width: 560px) {
    .brand-sub { display: none; }
    .nav-links { gap: 0.9rem; font-size: 0.72rem; }
  }
</style>
