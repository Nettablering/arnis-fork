[Unit]
Description=Worldbuilders DataStore overlay backup (Q099)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/projects/worldbuilders/backend/datastore-backup
EnvironmentFile=-/home/deploy/projects/worldbuilders/backend/datastore-backup/.env
ExecStart=/home/deploy/projects/worldbuilders/backend/datastore-backup/target/release/wb-backup --universe-id ${WB_UNIVERSE_ID}

# Hardening (mirrors bake-server pattern)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/deploy/projects/worldbuilders/backups /home/deploy/projects/worldbuilders/backend/datastore-backup
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
